# Copy this file to .env and fill in real values. Never commit .env.

# -----------------------------------------------------------------------------
# Postgres (Neon) — REQUIRED, Phase 1
# Provision a fresh Neon project (separate from exoplanet_citation).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neo_citation?sslmode=require

# dbt connection (parsed from your DATABASE_URL above; dbt-postgres needs them split).
# Only required once Phase 2 (dbt models) lands; safe to leave as-is for Phase 1.
DBT_HOST=ep-xxx.region.aws.neon.tech
DBT_USER=user
DBT_PASSWORD=password
DBT_DBNAME=neo_citation
DBT_PORT=5432
DBT_SCHEMA=public

# -----------------------------------------------------------------------------
# Snapshot storage backend
#
# Two modes:
#   r2     — production: snapshots go to Cloudflare R2 (requires all R2_* below)
#   local  — development: snapshots write to LOCAL_R2_DIR (default
#            data/snapshots/local-r2), no Cloudflare account needed
#
# If STORAGE_BACKEND is unset, the code auto-falls-back to local when any of
# the four R2_* vars (ENDPOINT_URL, ACCESS_KEY_ID, SECRET_ACCESS_KEY,
# BUCKET_NAME) is missing or empty.
# -----------------------------------------------------------------------------
# STORAGE_BACKEND=local
# LOCAL_R2_DIR=data/snapshots/local-r2

# Cloudflare R2 (only required if STORAGE_BACKEND=r2 or auto-detect picks r2).
# Note: Cloudflare's R2 API token UI inconsistently surfaces the S3 Access Key
# ID + Secret Access Key. If your token-creation success page only shows a
# bearer-style `cfat_…` token, leave these blank and the pipeline will use the
# local backend instead.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=close-encounters-snapshots
R2_ENDPOINT_URL=https://your-cloudflare-account-id.r2.cloudflarestorage.com

# -----------------------------------------------------------------------------
# NASA APIs
# -----------------------------------------------------------------------------
# NASA general API key — instant, free at https://api.nasa.gov.
# Currently optional in Phase 1: only used if NEOWS becomes the fallback path
# when SBDB+CNEOS rate-limit us. Recommended to populate now anyway.
NASA_API_KEY=your-nasa-api-key

# NASA ADS bibliography token — REQUIRED for Phase 3 (citation resolution).
# Apply at https://ui.adsabs.harvard.edu/user/settings/token (manual approval,
# can take a few days). If you already have an ADS token for another project
# you can reuse it here — the token is tied to your account, not the project.
ADS_API_TOKEN=your-ads-token

# -----------------------------------------------------------------------------
# Polite-pool identification — required by Crossref, encouraged by ADS,
# identifies us in NASA/JPL request logs.
# -----------------------------------------------------------------------------
USER_AGENT_EMAIL=mark@pernotto.com
USER_AGENT_PROJECT=neo_citation/0.1 (+https://github.com/markpernotto/close_encounters)
